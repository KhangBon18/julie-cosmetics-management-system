Project JulieCosmeticsCurrentSystem {
  database_type: 'MySQL'
  Note: 'ERD cho codebase hien tai cua Julie Cosmetics, doi chieu tu schema.sql + models/controllers + docs nghiep vu. Luu y: users giu ca role enum va role_id; invoices dong vai tro ca hoa don POS va don hang online; khong co bang cart/orders rieng; notifications, refresh_tokens, audit_logs dung lien ket da hinh nen khong khai bao FK cung.'
}

Enum user_role {
  admin
  manager
  staff
  warehouse
}

Enum employee_status {
  active
  inactive
}

Enum leave_type {
  annual
  sick
  maternity
  unpaid
  resignation
}

Enum leave_status {
  pending
  approved
  rejected
}

Enum membership_tier {
  standard
  silver
  gold
}

Enum invoice_payment_method {
  cash
  card
  transfer
}

Enum invoice_status {
  draft
  confirmed
  paid
  completed
  refunded
  cancelled
}

Enum promotion_discount_type {
  percent
  fixed
}

Enum import_status {
  completed
  cancelled
}

Enum payment_transaction_method {
  cash
  card
  transfer
  momo
  zalopay
  vnpay
}

Enum payment_status {
  pending
  confirmed
  failed
  refunded
}

Enum shipping_status {
  pending
  processing
  shipped
  delivered
  failed
  returned
}

Enum return_type {
  refund
  exchange
}

Enum return_status {
  requested
  approved
  processing
  completed
  rejected
}

Enum inventory_movement_type {
  import
  sale
  return
  adjustment
  damage
  transfer
}

Enum permission_action {
  read
  create
  update
  delete
  export
}

Enum notification_user_type {
  staff
  customer
}

Enum notification_level {
  info
  warning
  success
  error
}

Enum audit_user_type {
  staff
  customer
  system
}

Enum setting_data_type {
  string
  number
  boolean
  json
}

Table positions {
  position_id int [pk, increment]
  position_name varchar(100) [not null]
  base_salary decimal(12,2) [not null]
  description text
  created_at timestamp
  updated_at timestamp

  Note: 'Danh muc chuc vu.'
}

Table employees {
  employee_id int [pk, increment]
  full_name varchar(100) [not null]
  email varchar(100) [not null, unique]
  phone varchar(15)
  address text
  gender varchar(10) [note: 'MySQL enum("Nam","Nu") trong he thong thuc te.']
  date_of_birth date
  hire_date date [not null]
  base_salary decimal(12,2) [not null]
  status employee_status [not null]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp

  Note: 'Ho so nhan vien; chuc vu hien tai lay tu employee_positions co end_date IS NULL.'
}

Table employee_positions {
  id int [pk, increment]
  employee_id int [not null]
  position_id int [not null]
  effective_date date [not null]
  end_date date
  salary_at_time decimal(12,2) [not null]
  note text
  created_at timestamp

  Note: 'Luu lich su chuc vu va muc luong theo thoi diem.'
}

Table roles {
  role_id int [pk, increment]
  role_name varchar(50) [not null, unique]
  description varchar(255)
  is_system boolean [not null]
  created_at timestamp
  updated_at timestamp

  Note: 'Vai tro RBAC hien tai.'
}

Table permissions {
  permission_id int [pk, increment]
  permission_name varchar(100) [not null, unique]
  module varchar(50) [not null]
  action permission_action [not null]
  description varchar(255)
  created_at timestamp

  indexes {
    (module, action) [unique, name: 'uq_perm_module_action']
  }
}

Table role_permissions {
  role_id int [pk, not null]
  permission_id int [pk, not null]

  Note: 'Bang trung gian N-N giua roles va permissions.'
}

Table users {
  user_id int [pk, increment]
  username varchar(50) [not null, unique]
  password_hash varchar(255) [not null]
  role user_role [not null, note: 'Legacy enum duoc giu lai de backward compatibility.']
  role_id int [note: 'FK RBAC hien tai.']
  employee_id int
  is_active boolean [not null]
  last_login timestamp
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp

  Note: 'Tai khoan dang nhap noi bo. He thong hien tai song song role enum cu va role_id moi.'
}

Table leave_requests {
  request_id int [pk, increment]
  employee_id int [not null]
  leave_type leave_type [not null]
  start_date date [not null]
  end_date date [not null]
  total_days int [not null]
  reason text [not null]
  status leave_status [not null]
  approved_by int
  approved_at timestamp
  reject_reason text
  created_at timestamp

  Note: 'Codebase hien tai da ho tro resignation nhu mot loai don nghi viec.'
}

Table salaries {
  salary_id int [pk, increment]
  employee_id int [not null]
  month int [not null]
  year year [not null]
  work_days_standard int [not null]
  work_days_actual int [not null]
  unpaid_leave_days int [not null]
  base_salary decimal(12,2) [not null]
  gross_salary decimal(12,2) [not null]
  bonus decimal(12,2) [not null]
  deductions decimal(12,2) [not null]
  net_salary decimal(12,2) [not null]
  notes text
  generated_at timestamp
  generated_by int

  indexes {
    (employee_id, month, year) [unique, name: 'uq_emp_month']
  }
}

Table brands {
  brand_id int [pk, increment]
  brand_name varchar(100) [not null]
  origin_country varchar(100)
  description text
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

Table categories {
  category_id int [pk, increment]
  parent_id int
  category_name varchar(100) [not null]
  description text
  created_at timestamp
  updated_at timestamp

  Note: 'Danh muc tu tham chieu, ho tro danh muc cha/con.'
}

Table suppliers {
  supplier_id int [pk, increment]
  supplier_name varchar(200) [not null]
  contact_person varchar(100)
  phone varchar(15)
  email varchar(100)
  address text
  is_active boolean [not null]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp
}

Table products {
  product_id int [pk, increment]
  product_name varchar(200) [not null]
  brand_id int [not null]
  category_id int [not null]
  description text
  skin_type varchar(100) [note: 'Thuoc tinh legacy van dang duoc UI/API su dung truc tiep.']
  volume varchar(50)
  import_price decimal(12,2) [not null]
  sell_price decimal(12,2) [not null]
  stock_quantity int [not null]
  image_url varchar(255)
  is_active boolean [not null]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp

  Note: 'Vua co skin_type text legacy, vua co mo hinh chuan hoa skin_types/product_skin_types.'
}

Table product_images {
  image_id int [pk, increment]
  product_id int [not null]
  image_url varchar(500) [not null]
  alt_text varchar(200)
  sort_order int [not null]
  is_primary boolean [not null]
  created_at timestamp

  Note: '1 san pham co nhieu anh; trang thai primary dang duoc dam bao boi service, khong phai unique constraint DB.'
}

Table skin_types {
  skin_type_id int [pk, increment]
  skin_type_name varchar(100) [not null, unique]
  description varchar(255)
  created_at timestamp

  Note: 'Bang chuan hoa da co trong DB, nhung UI/model hien tai chua khai thac day du.'
}

Table product_skin_types {
  product_id int [pk, not null]
  skin_type_id int [pk, not null]

  Note: 'Bang lien ket N-N cho loai da phu hop.'
}

Table import_receipts {
  receipt_id int [pk, increment]
  supplier_id int [not null]
  created_by int
  total_amount decimal(12,2) [not null]
  status import_status [not null]
  note text
  created_at timestamp
}

Table import_receipt_items {
  item_id int [pk, increment]
  receipt_id int [not null]
  product_id int [not null]
  quantity int [not null]
  unit_price decimal(12,2) [not null]
}

Table inventory_movements {
  movement_id bigint [pk, increment]
  product_id int [not null]
  movement_type inventory_movement_type [not null]
  quantity int [not null]
  stock_before int [not null]
  stock_after int [not null]
  reference_type varchar(50)
  reference_id int
  unit_cost decimal(12,2)
  note text
  created_by int
  created_at timestamp

  Note: 'Bang su kien kho. reference_type/reference_id la lien ket da hinh toi import_receipt, invoice, return, manual...'
}

Table customers {
  customer_id int [pk, increment]
  full_name varchar(100) [not null]
  phone varchar(15) [not null, unique]
  email varchar(100)
  password_hash varchar(255) [note: 'NULL = khach CRM chua kich hoat tai khoan online.']
  address text [note: 'Dia chi ho so/legacy; da co customer_addresses cho mo hinh da dia chi.']
  gender varchar(10) [note: 'MySQL enum("Nam","Nu") trong he thong thuc te.']
  date_of_birth date
  membership_tier membership_tier [not null]
  total_points int [not null]
  total_spent decimal(12,2) [not null]
  created_at timestamp
  updated_at timestamp
  deleted_at timestamp

  Note: '1 bang vua phuc vu CRM, vua phuc vu customer account cua storefront.'
}

Table customer_addresses {
  address_id int [pk, increment]
  customer_id int [not null]
  label varchar(50)
  recipient varchar(100) [not null]
  phone varchar(15) [not null]
  province varchar(100) [not null]
  district varchar(100) [not null]
  ward varchar(100)
  street varchar(255) [not null]
  is_default boolean [not null]
  created_at timestamp
  updated_at timestamp

  Note: 'Mot khach hang co nhieu dia chi; chi mot dia chi mac dinh duoc service dam bao.'
}

Table promotions {
  promotion_id int [pk, increment]
  code varchar(50) [unique, note: 'NULL = auto-apply promotion.']
  title varchar(200) [not null]
  description text
  discount_type promotion_discount_type [not null]
  discount_value decimal(12,2) [not null]
  min_order decimal(12,2) [not null]
  max_discount decimal(12,2)
  usage_limit int
  usage_count int [not null]
  start_date datetime [not null]
  end_date datetime [not null]
  is_active boolean [not null]
  created_by int
  created_at timestamp
  updated_at timestamp
}

Table invoices {
  invoice_id int [pk, increment]
  customer_id int [note: 'NULL = khach vang lai/guest checkout.']
  created_by int [note: 'NULL = don online/public checkout hoac he thong.']
  subtotal decimal(12,2) [not null]
  discount_percent decimal(5,2) [not null]
  discount_amount decimal(12,2) [not null]
  final_total decimal(12,2) [not null]
  points_earned int [not null]
  payment_method invoice_payment_method [not null]
  status invoice_status [not null]
  promotion_id int
  note text
  created_at timestamp
  updated_at timestamp

  Note: 'Khong co bang orders rieng; invoices la thuc the trung tam cho ban tai quay va dat hang online.'
}

Table invoice_items {
  item_id int [pk, increment]
  invoice_id int [not null]
  product_id int [not null]
  quantity int [not null]
  unit_price decimal(12,2) [not null]
  subtotal decimal(12,2) [not null]
}

Table reviews {
  review_id int [pk, increment]
  product_id int [not null]
  customer_id int
  rating int [not null]
  comment text
  is_visible boolean [not null]
  created_at timestamp
  updated_at timestamp

  indexes {
    (customer_id, product_id) [unique, name: 'uq_customer_product']
  }
}

Table payment_transactions {
  transaction_id bigint [pk, increment]
  invoice_id int [not null]
  amount decimal(12,2) [not null]
  payment_method payment_transaction_method [not null]
  status payment_status [not null]
  transaction_ref varchar(100)
  gateway_response json
  note text
  confirmed_by int
  confirmed_at timestamp
  created_at timestamp

  Note: '1 invoice co the co nhieu lan giao dich/thu thanh toan.'
}

Table shipping_orders {
  shipping_id int [pk, increment]
  invoice_id int [not null, unique]
  address_id int [note: 'Co the NULL khi don online luu snapshot dia chi text thay vi tham chieu address book.']
  recipient_name varchar(100) [not null]
  recipient_phone varchar(15) [not null]
  shipping_address text [not null]
  status shipping_status [not null]
  tracking_code varchar(100)
  shipping_fee decimal(12,2) [not null]
  shipped_at timestamp
  delivered_at timestamp
  note text
  created_at timestamp
  updated_at timestamp
}

Table returns {
  return_id int [pk, increment]
  invoice_id int [not null]
  customer_id int
  return_type return_type [not null]
  status return_status [not null]
  reason text [not null]
  total_refund decimal(12,2) [not null]
  approved_by int
  approved_at timestamp
  completed_at timestamp
  note text
  created_at timestamp
  updated_at timestamp
}

Table return_items {
  item_id int [pk, increment]
  return_id int [not null]
  product_id int [not null]
  quantity int [not null]
  unit_price decimal(12,2) [not null]
  refund_subtotal decimal(12,2) [not null, note: 'Can cho refund analytics va partial refund.']
  reason varchar(255)

  Note: 'Codebase hien tai su dung refund_subtotal; neu Docker volume cu chua reset thi cot nay co the chua co trong DB demo.'
}

Table settings {
  setting_id int [pk, increment]
  setting_key varchar(100) [not null, unique]
  setting_value text [not null]
  data_type setting_data_type [not null]
  category varchar(50) [not null]
  description varchar(255)
  is_public boolean [not null]
  updated_at timestamp
  updated_by int
}

Table notifications {
  notification_id bigint [pk, increment]
  user_id int
  user_type notification_user_type [not null]
  title varchar(200) [not null]
  message text [not null]
  type notification_level [not null]
  is_read boolean [not null]
  link varchar(500)
  created_at timestamp

  Note: 'Lien ket user da hinh staff/customer, vi vay khong tao FK cung.'
}

Table refresh_tokens {
  token_id bigint [pk, increment]
  user_id int [not null]
  user_type notification_user_type [not null]
  token_hash varchar(255) [not null, unique]
  device_info varchar(255)
  ip_address varchar(45)
  expires_at timestamp [not null]
  revoked_at timestamp
  created_at timestamp

  Note: 'Lien ket user da hinh staff/customer, vi vay khong tao FK cung.'
}

Table login_attempts {
  attempt_id bigint [pk, increment]
  identifier varchar(100) [not null]
  ip_address varchar(45) [not null]
  user_agent varchar(500)
  success boolean [not null]
  failure_reason varchar(100)
  created_at timestamp

  Note: 'Bang bao mat/phong brute-force, khong rang buoc FK vao user vi identifier co the chua ton tai.'
}

Table audit_logs {
  log_id bigint [pk, increment]
  user_id int
  user_type audit_user_type [not null]
  action varchar(50) [not null]
  entity_type varchar(50) [not null]
  entity_id int
  old_values json
  new_values json
  ip_address varchar(45)
  user_agent varchar(500)
  created_at timestamp

  Note: 'Audit trail da hinh cho staff/customer/system va cho moi loai thuc the, nen khong dung FK cung.'
}

Ref: employee_positions.employee_id > employees.employee_id
Ref: employee_positions.position_id > positions.position_id

Ref: users.employee_id > employees.employee_id
Ref: users.role_id > roles.role_id

Ref: role_permissions.role_id > roles.role_id
Ref: role_permissions.permission_id > permissions.permission_id

Ref: leave_requests.employee_id > employees.employee_id
Ref: leave_requests.approved_by > users.user_id

Ref: salaries.employee_id > employees.employee_id
Ref: salaries.generated_by > users.user_id

Ref: categories.parent_id > categories.category_id

Ref: products.brand_id > brands.brand_id
Ref: products.category_id > categories.category_id

Ref: product_images.product_id > products.product_id

Ref: product_skin_types.product_id > products.product_id
Ref: product_skin_types.skin_type_id > skin_types.skin_type_id

Ref: import_receipts.supplier_id > suppliers.supplier_id
Ref: import_receipts.created_by > users.user_id

Ref: import_receipt_items.receipt_id > import_receipts.receipt_id
Ref: import_receipt_items.product_id > products.product_id

Ref: inventory_movements.product_id > products.product_id
Ref: inventory_movements.created_by > users.user_id

Ref: customer_addresses.customer_id > customers.customer_id

Ref: promotions.created_by > users.user_id

Ref: invoices.customer_id > customers.customer_id
Ref: invoices.created_by > users.user_id
Ref: invoices.promotion_id > promotions.promotion_id

Ref: invoice_items.invoice_id > invoices.invoice_id
Ref: invoice_items.product_id > products.product_id

Ref: reviews.product_id > products.product_id
Ref: reviews.customer_id > customers.customer_id

Ref: payment_transactions.invoice_id > invoices.invoice_id
Ref: payment_transactions.confirmed_by > users.user_id

Ref: shipping_orders.invoice_id > invoices.invoice_id
Ref: shipping_orders.address_id > customer_addresses.address_id

Ref: returns.invoice_id > invoices.invoice_id
Ref: returns.customer_id > customers.customer_id
Ref: returns.approved_by > users.user_id

Ref: return_items.return_id > returns.return_id
Ref: return_items.product_id > products.product_id

Ref: settings.updated_by > users.user_id
