Project JulieCosmeticsCurrentSystem {
  database_type: "MySQL"
  Note: "Core ERD de chen bao cao va doi chieu nhanh voi schema.sql. Ban nay uu tien thuc the cot loi cua HTTT hien tai."
}

Table employees {
  employee_id int [pk, increment]
  full_name varchar
  email varchar
  phone varchar
  hire_date date
  base_salary decimal
  status varchar
}

Table positions {
  position_id int [pk, increment]
  position_name varchar
  base_salary decimal
}

Table employee_positions {
  id int [pk, increment]
  employee_id int [not null]
  position_id int [not null]
  effective_date date
  end_date date
  salary_at_time decimal
}

Table users {
  user_id int [pk, increment]
  username varchar
  role varchar [note: "Legacy enum"]
  role_id int [note: "FK toi roles - mo hinh RBAC hien tai"]
  employee_id int
  is_active boolean
}

Table roles {
  role_id int [pk, increment]
  role_name varchar
  is_system boolean
}

Table permissions {
  permission_id int [pk, increment]
  permission_name varchar
  module varchar
  action varchar
}

Table role_permissions {
  role_id int [not null]
  permission_id int [not null]
}

Table leave_requests {
  request_id int [pk, increment]
  employee_id int [not null]
  leave_type varchar
  start_date date
  end_date date
  total_days int
  status varchar
  approved_by int
}

Table salaries {
  salary_id int [pk, increment]
  employee_id int [not null]
  month int
  year int
  base_salary decimal
  gross_salary decimal
  bonus decimal
  deductions decimal
  net_salary decimal
  generated_by int
}

Table salary_bonus_adjustments {
  bonus_id int [pk, increment]
  employee_id int [not null]
  month int
  year int
  amount decimal
  reason varchar
  created_by int
  updated_by int
}

Table brands {
  brand_id int [pk, increment]
  brand_name varchar
}

Table categories {
  category_id int [pk, increment]
  category_name varchar
}

Table suppliers {
  supplier_id int [pk, increment]
  supplier_name varchar
  contact_person varchar
  is_active boolean
}

Table products {
  product_id int [pk, increment]
  product_name varchar
  brand_id int [not null]
  category_id int [not null]
  skin_type varchar [note: "Legacy/display nhanh"]
  import_price decimal
  sell_price decimal
  stock_quantity int
  is_active boolean
}

Table supplier_products {
  supplier_id int [not null]
  product_id int [not null]
  is_active boolean
}

Table import_receipts {
  receipt_id int [pk, increment]
  supplier_id int [not null]
  created_by int
  total_amount decimal
  status varchar
}

Table import_receipt_items {
  item_id int [pk, increment]
  receipt_id int [not null]
  product_id int [not null]
  quantity int
  unit_price decimal
}

Table inventory_movements {
  movement_id bigint [pk, increment]
  product_id int [not null]
  movement_type varchar
  quantity int
  reference_type varchar
  reference_id int
  created_by int
}

Table customers {
  customer_id int [pk, increment]
  full_name varchar
  phone varchar
  email varchar
  membership_tier varchar
  total_points int
  total_spent decimal
}

Table invoices {
  invoice_id int [pk, increment]
  customer_id int
  created_by int
  final_total decimal
  points_earned int
  payment_method varchar
  status varchar
  promotion_id int
}

Table invoice_items {
  item_id int [pk, increment]
  invoice_id int [not null]
  product_id int [not null]
  quantity int
  unit_price decimal
  subtotal decimal
}

Table payment_transactions {
  transaction_id int [pk, increment]
  invoice_id int [not null]
  amount decimal
  payment_method varchar
  status varchar
  confirmed_by int
}

Table reviews {
  review_id int [pk, increment]
  product_id int [not null]
  customer_id int
  rating int
  is_visible boolean
}

Table settings {
  setting_id int [pk, increment]
  setting_key varchar
  setting_value text
  category varchar
}

Table notifications {
  notification_id int [pk, increment]
  user_id int
  user_type varchar
  title varchar
  is_read boolean
}

Table refresh_tokens {
  token_id int [pk, increment]
  user_id int
  user_type varchar
}

Table login_attempts {
  attempt_id int [pk, increment]
  identifier varchar
  success boolean
}

Table audit_logs {
  log_id bigint [pk, increment]
  user_id int
  user_type varchar
  action varchar
  entity_type varchar
  entity_id int
}

Ref: employee_positions.employee_id > employees.employee_id
Ref: employee_positions.position_id > positions.position_id
Ref: users.employee_id > employees.employee_id
Ref: users.role_id > roles.role_id
Ref: role_permissions.role_id > roles.role_id
Ref: role_permissions.permission_id > permissions.permission_id
Ref: leave_requests.employee_id > employees.employee_id
Ref: leave_requests.approved_by > users.user_id
Ref: salaries.employee_id > employees.employee_id
Ref: salaries.generated_by > users.user_id
Ref: salary_bonus_adjustments.employee_id > employees.employee_id
Ref: salary_bonus_adjustments.created_by > users.user_id
Ref: salary_bonus_adjustments.updated_by > users.user_id
Ref: products.brand_id > brands.brand_id
Ref: products.category_id > categories.category_id
Ref: supplier_products.supplier_id > suppliers.supplier_id
Ref: supplier_products.product_id > products.product_id
Ref: import_receipts.supplier_id > suppliers.supplier_id
Ref: import_receipts.created_by > users.user_id
Ref: import_receipt_items.receipt_id > import_receipts.receipt_id
Ref: import_receipt_items.product_id > products.product_id
Ref: inventory_movements.product_id > products.product_id
Ref: inventory_movements.created_by > users.user_id
Ref: invoices.customer_id > customers.customer_id
Ref: invoices.created_by > users.user_id
Ref: invoice_items.invoice_id > invoices.invoice_id
Ref: invoice_items.product_id > products.product_id
Ref: payment_transactions.invoice_id > invoices.invoice_id
Ref: payment_transactions.confirmed_by > users.user_id
Ref: reviews.product_id > products.product_id
Ref: reviews.customer_id > customers.customer_id
